PORT=3000

# Required for /auth/register and /auth/login through Firebase Identity Toolkit
FIREBASE_WEB_API_KEY=your_firebase_web_api_key

# Option A: Full service account JSON as a single-line string
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Option B: Individual service account fields
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional: use Firestore and Auth emulators for local offline development
FIRESTORE_EMULATOR_HOST=127.0.0.1:8085
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
